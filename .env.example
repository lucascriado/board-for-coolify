# URL base da instância Coolify (sem barra no final)
# Exemplo: https://coolify.seudominio.com
COOLIFY_BASE_URL=https://coolify.example.com

# Token da API do Coolify
# Obtenha em: Settings > API Tokens > Create Token
COOLIFY_API_TOKEN=

# URL pública do Coolify usada para gerar links externos no dashboard
# Normalmente igual ao COOLIFY_BASE_URL
NEXT_PUBLIC_COOLIFY_URL=https://coolify.example.com
